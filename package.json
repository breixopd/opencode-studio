{
  "name": "opencode-studio",
  "version": "2.0.0",
  "description": "OpenCode dev platform — zero-config remote sync, subagents, and keyless search",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "rules", "agents"],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --external @opencode-ai/plugin --external ssh2",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "dev": "bun build src/index.ts --outdir dist --target node --external @opencode-ai/plugin --watch",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.1.51",
    "@types/bun": "^1.3.0",
    "@types/ssh2": "^1.15.5",
    "typescript": "^5.9.0"
  },
  "keywords": ["opencode", "opencode-plugin", "remote-development", "ssh", "sync", "studio", "subagents", "zero-config"],
  "license": "MIT",
  "dependencies": {
    "chokidar": "^5.0.0",
    "ssh2": "^1.17.0",
    "zod": "^4.4.3"
  }
}
