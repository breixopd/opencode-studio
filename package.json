{
  "name": "opencode-studio",
  "version": "2.0.0",
  "description": "OpenCode dev platform — zero-config remote sync, subagents, and keyless search",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "rules"],
  "scripts": {
    "prebuild": "mkdir -p dist && cp src/core/studio-db-schema.sql dist/",
    "build": "bun build src/index.ts --outdir dist --target bun --external @opencode-ai/plugin --external ssh2 --external web-tree-sitter --external tree-sitter-wasms",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "predev": "mkdir -p dist && cp src/core/studio-db-schema.sql dist/",
    "dev": "bun build src/index.ts --outdir dist --target bun --external @opencode-ai/plugin --external ssh2 --external web-tree-sitter --external tree-sitter-wasms --watch",
    "prepublishOnly": "bun run build"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.1.51",
    "@types/bun": "^1.3.0",
    "@types/ssh2": "^1.15.5",
    "@types/turndown": "^5.0.6",
    "typescript": "^6.0.3"
  },
  "keywords": ["opencode", "opencode-plugin", "remote-development", "ssh", "sync", "studio", "subagents", "zero-config"],
  "license": "MIT",
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "chokidar": "^5.0.0",
    "linkedom": "^0.18.12",
    "ssh2": "^1.17.0",
    "tree-sitter-wasms": "^0.1.13",
    "turndown": "^7.2.4",
    "web-tree-sitter": "0.25.10",
    "zod": "^4.4.3"
  }
}
